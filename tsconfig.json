{
  "compilerOptions": {
    "rootDir": ".",
    // allow resolution of packages that live in the example workspace
    // (react-native and friends are only installed there during development)
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "example/node_modules/*"],
      "rn-arrow-chessboard": ["./src/index"]
    },
    "typeRoots": ["node_modules/@types", "example/node_modules/@types"],
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "customConditions": ["react-native-strict-api"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitUseStrict": false,
    "noStrictGenericChecks": false,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "verbatimModuleSyntax": true
  },
  "include": [
    "src",
    "types",
    "example/**/*.ts",
    "example/**/*.tsx"
  ]
}
